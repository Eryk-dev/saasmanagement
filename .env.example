# ── API (packages/api) ─────────────────────────────────────────────
# Porta em que a API REST escuta.
API_PORT=8787
# Opcional. Se definido, escritas (POST/PATCH/DELETE) exigem o header:
#   x-api-key: <este valor>
# Leituras continuam abertas para o app web conseguir dar bootstrap sem key embutida.
COCKPIT_API_KEY=

# ── Servidor MCP (packages/mcp) ────────────────────────────────────
# Porta do servidor MCP Streamable-HTTP (endpoint: POST /mcp).
MCP_PORT=8788
# URL base que o servidor MCP usa pra alcançar a API.
COCKPIT_API_URL=http://localhost:8787
# Se a API exigir key, o MCP a repassa nas escritas.
# (cai pro COCKPIT_API_KEY acima se não definido)
# MCP_API_KEY=

# ── Web (packages/web) ─────────────────────────────────────────────
# Em dev, o Vite faz proxy de /api pra API, então deixe vazio.
# Para um build de produção apontando pra uma API remota, defina a URL base completa.
VITE_API_BASE=
