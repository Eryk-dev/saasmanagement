# ── API (packages/api) ─────────────────────────────────────────────
# Porta em que a API REST escuta.
API_PORT=8787
# Banco: Supabase Postgres. OBRIGATÓRIO — é onde TODOS os dados ficam (persistente,
# sobrevive a redeploy/down/rebuild do container). Pegue a connection string em
# Supabase → Project → Settings → Database → Connection string (use o pooler). O app
# cria sozinho o schema `cockpit` + as tabelas no primeiro boot.
# Ex.: postgresql://postgres.<ref>:<senha>@aws-1-<regiao>.pooler.supabase.com:6543/postgres?sslmode=require
COCKPIT_DB_URL=
# Segredo de acesso. Se definido, TODA rota da API exige a chave (leituras E
# escritas), via header `x-api-key: <valor>` ou `Authorization: Bearer <valor>`.
# Só /api/health fica aberto (liveness). Vazio = tudo aberto (use só em dev/local).
# A UI pede essa chave numa tela de senha; o MCP a repassa. UM segredo protege tudo.
COCKPIT_API_KEY=

# ── Servidor MCP (packages/mcp) ────────────────────────────────────
# Porta do servidor MCP Streamable-HTTP (endpoint: POST /mcp).
MCP_PORT=8788
# URL base que o servidor MCP usa pra alcançar a API.
COCKPIT_API_URL=http://localhost:8787
# Auth do endpoint /mcp: se definido, todo request ao /mcp exige a chave
# (x-api-key ou Bearer). Cai pro COCKPIT_API_KEY se não definido — então a mesma
# chave protege API + MCP. O MCP também a repassa pra API.
# MCP_AUTH_KEY=
# Chave que o MCP usa AO CHAMAR a API (cai pro COCKPIT_API_KEY se vazio).
# MCP_API_KEY=

# ── Integração Levercopy (Cockpit → Levercopy) ─────────────────────
# Ao criar um lead manual do SaaS Levercopy, o Cockpit chama o Levercopy pra gerar
# a proposta dinâmica (POST {LEVERCOPY_API_URL}/api/proposta/generate, header
# X-Cockpit-Key) e grava proposta_id/proposalUrl/proposal_edit_url no lead.
# Sem LEVERCOPY_INGEST_KEY a integração fica DESLIGADA graciosamente (fail-open).
# URL base da API do Levercopy.
LEVERCOPY_API_URL=https://leverads.com.br
# Segredo compartilhado enviado em X-Cockpit-Key. DEVE bater com a COCKPIT_INGEST_KEY
# configurada no Levercopy (o mesmo valor nos dois lados).
LEVERCOPY_INGEST_KEY=
# id do produto/funil que identifica os leads do Levercopy (campo `saas` do lead).
LEVERCOPY_SAAS_ID=leverads

# ── Mercado Pago (billing — assinaturas) ───────────────────────────
# Access token da aplicação MP (produção ou sandbox). Vazio = integração
# desligada graciosamente (botão "cobrar via MP" não aparece na UI).
MERCADOPAGO_ACCESS_TOKEN=
# Secret do webhook (painel MP → Webhooks → Configurações avançadas).
# Configure a URL do webhook no painel: https://<host>/public/mp/webhook
# Vazio = assinatura do webhook NÃO é verificada (ok em sandbox; em produção
# defina sempre — o handler re-busca o recurso na API de toda forma).
MERCADOPAGO_WEBHOOK_SECRET=
# Base das URLs públicas (links de form/proposta gravados no lead + back_url
# do checkout MP). Em produção, o domínio do app.
COCKPIT_PUBLIC_URL=

# ── Meta Ads (marketing — insights de campanha) ────────────────────
# Token longo de system user (Business Settings → System users) com permissão
# ads_read nas contas de anúncio. Vazio = integração desligada graciosamente.
# A conta de anúncio (act_…) é POR SAAS: Ajustes → Integrações.
META_ACCESS_TOKEN=

# ── Web (packages/web) ─────────────────────────────────────────────
# Em dev, o Vite faz proxy de /api pra API, então deixe vazio.
# Para um build de produção apontando pra uma API remota, defina a URL base completa.
VITE_API_BASE=
